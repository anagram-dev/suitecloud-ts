{
  "name": "suitecloud-acp-ts",
  "version": "1.0.0",
  "description": "SuiteCloud Account Customization Project with TypeScript support",
  "author": "Joaquin Gatica <me@joaquingatica.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joaquingatica/suitecloud-acp-ts.git"
  },
  "license": "MIT",
  "scripts": {
    "build:ts": "tsc",
    "build:static": "copyfiles -u 1 -e \"./src/SuiteScripts/**/*.ts\" \"./src/SuiteScripts/**/*\" ./src/FileCabinet/",
    "build": "concurrently \"npm:build:*\"",
    "clean": "rimraf ./src/FileCabinet/SuiteScripts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^9.39.1",
    "@eslint/json": "^0.14.0",
    "@eslint/markdown": "^7.5.1",
    "@hitc/netsuite-types": "^2025.2.10",
    "@oracle/suitecloud-cli": "^3.1.0",
    "@oracle/suitecloud-unit-testing": "^1.7.0",
    "@types/jest": "29.5.14",
    "concurrently": "^9.2.1",
    "copyfiles": "^2.4.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.2.1",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-requirejs": "^4.0.1",
    "husky": "^9.1.7",
    "jest": "29.7.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3"
  }
}
