{
  "name": "suitecloud-ts",
  "version": "1.0.0",
  "description": "SuiteCloud Account Customization Project with TypeScript support",
  "author": "Joaquin Gatica <me@joaquingatica.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joaquingatica/suitecloud-ts.git"
  },
  "license": "MIT",
  "scripts": {
    "build:ts": "tsc",
    "build:static": "copyfiles -u 1 -e \"./src/SuiteScripts/**/*.ts\" \"./src/SuiteScripts/**/*\" ./src/FileCabinet/",
    "build": "concurrently \"npm:build:*\"",
    "clean": "rimraf ./src/FileCabinet/SuiteScripts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^9.39.4",
    "@eslint/json": "^2.0.1",
    "@eslint/markdown": "^8.0.3",
    "@hitc/netsuite-types": "^2026.1.7",
    "@oracle/suitecloud-cli": "^3.2.0",
    "@oracle/suitecloud-unit-testing": "^1.8.0",
    "@types/jest": "^30.0.0",
    "concurrently": "^10.0.3",
    "copyfiles": "^2.4.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.4",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-requirejs": "^4.0.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^16.4.0",
    "prettier": "^3.9.4",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  }
}
