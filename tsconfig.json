{
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2023",
    "lib": ["es2023"],
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noEmit": true,
    "paths": {
      "N": ["./node_modules/@hitc/netsuite-types/N"],
      "N/*": ["./node_modules/@hitc/netsuite-types/N/*"]
    }
  },
  "include": ["src/SuiteScripts/**/*"]
}
