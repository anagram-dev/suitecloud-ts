{
  "compilerOptions": {
    "module": "amd",
    "target": "es2023",
    "moduleResolution": "node",
    "lib": ["es2023"],
    "strict": true,
    "ignoreDeprecations": "6.0",
    "exactOptionalPropertyTypes": true,
    "allowJs": true,
    "outDir": "src/FileCabinet/SuiteScripts/",
    "rootDir": "src/SuiteScripts",
    "paths": {
      "N": ["./node_modules/@hitc/netsuite-types/N"],
      "N/*": ["./node_modules/@hitc/netsuite-types/N/*"]
    }
  },
  "include": ["src/SuiteScripts/**/*"]
}
